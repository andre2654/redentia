{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build:host-map": "tsx scripts/generate-host-map.ts",
    "build": "npm run build:host-map && nuxt build",
    "dev": "nuxt dev",
    "generate": "npm run build:host-map && nuxt generate",
    "preview": "nuxt preview",
    "start": "nuxt start",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "nuxt prepare",
    "pretty": "prettier --write \"./**/*.{vue,js,jsx,mjs,cjs,ts,tsx,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"app/**/*.{vue,css}\"",
    "lint:css:fix": "stylelint \"app/**/*.{vue,css}\" --fix",
    "lint:colors": "echo '\\n[1/2] Stylelint (CSS hex literals):\\n' && npm run lint:css; echo '\\n[2/2] ESLint (template :style anti-pattern):\\n' && eslint \"app/components/**/*.vue\" \"app/pages/**/*.vue\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@kurkle/color": "0.4.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "3.3.0",
    "@pinia/nuxt": "0.5.3",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@tiptap/vue-3": "^3.23.1",
    "@types/dompurify": "^3.0.5",
    "@vercel/analytics": "1.5.0",
    "@vite-pwa/nuxt": "1.0.4",
    "chart.js": "4.5.0",
    "chartjs-chart-treemap": "3.1.0",
    "cytoscape": "^3.34.0",
    "dompurify": "^3.4.2",
    "fast-average-color": "^9.5.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "html2canvas-pro": "^2.0.2",
    "isomorphic-dompurify": "2.31.0",
    "marked": "17.0.0",
    "maska": "3.2.0",
    "nuxt": "4.0.1",
    "pinia": "2.2.1",
    "pluggy-connect-sdk": "^2.13.0",
    "vue": "3.5.17",
    "vue-chartjs": "5.3.2",
    "vue-currency-input": "^3.2.1",
    "vue-router": "4.5.1",
    "xlsx": "^0.18.5",
    "zod": "4.0.14"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@nuxt/eslint": "0.5.1",
    "@nuxtjs/sitemap": "7.4.7",
    "@pinia-plugin-persistedstate/nuxt": "1.2.1",
    "eslint": "9.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "postcss-html": "^1.8.1",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.6",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.19.2",
    "vite-svg-loader": "5.1.0",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "9.4.3"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  }
}
